# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Azure AD (Microsoft Entra) — get these from your Azure portal app registration
AZURE_AD_CLIENT_ID="your-azure-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_TENANT_ID="your-azure-tenant-id"

# Demo mode — set to true to enable the demo role switcher (development only)
DEMO_AUTH_ENABLED="true"
NEXT_PUBLIC_DEMO_AUTH_ENABLED="true"

# HIS (Hospital Information System) — read-only SQL Server connection
# Format: "Server=HOST,PORT;Database=DB;User Id=USER;Password=PASS;Encrypt=True;TrustServerCertificate=True;ApplicationIntent=ReadOnly"
# Leave blank to disable HIS integration (form will work with manual entry only)
HIS_DATABASE_URL=""
