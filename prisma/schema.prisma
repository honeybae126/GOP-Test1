// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// This is your Prisma schema file for GOP Automation app metadata (non-canonical).
// FHIR data lives in HAPI FHIR server.

// Define your models below.

enum NotificationEvent {
  REQUEST_CREATED
  REQUEST_ASSIGNED
  REQUEST_REASSIGNED
  REQUEST_VERIFIED
  REQUEST_CORRECTION_REQUESTED
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_EXPIRED
  PDF_DOWNLOADED
}

enum AuditActorRole {
  ADMIN
  STAFF
  DOCTOR
  SYSTEM
}

enum AuditAction {
  REQUEST_CREATED
  REQUEST_UPDATED
  REQUEST_ASSIGNED
  REQUEST_REASSIGNED
  REQUEST_SUBMITTED_FOR_VERIFICATION
  REQUEST_VERIFIED
  REQUEST_CORRECTION_REQUESTED
  REQUEST_SUBMITTED_TO_INSURER
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_EXPIRED
  PDF_GENERATED
  PDF_DOWNLOADED
  NOTES_CREATED
  NOTES_EDITED
  USER_CREATED
  USER_DEACTIVATED
  USER_ROLE_CHANGED
  EXPIRY_WARNING_SENT
  BILLING_QUOTE_CREATED
  BILLING_QUOTE_UPDATED
  BILLING_QUOTE_FINALISED
  BILLING_GOP_CREATED
}

enum BillingStatus {
  DRAFT
  FINALISED
  GOP_CREATED
}

model Notification {
  id            String      @id @default(cuid())
  recipientId   String
  recipientRole Role
  eventType     NotificationEvent
  requestId     String?
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  metadata      Json             @default("{}")

  recipient     UserMetadata     @relation(fields: [recipientId], references: [id])
  gopRequest    GOPRequest?      @relation(fields: [requestId], references: [id])

  @@unique([id])
  @@index([recipientId, readAt])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([requestId])
  @@map("notifications")
}

model AuditEntry {
  id           String      @id @default(cuid())
  requestId    String?
  actorId      String?
  actorRole    AuditActorRole
  action       AuditAction
  beforeState  Json?
  afterState   Json?
  ipAddress    String?
  sessionId    String?
  metadata     Json?         @default("{}")
  createdAt    DateTime      @default(now())

  actor        UserMetadata? @relation(fields: [actorId], references: [id])
  gopRequest   GOPRequest?   @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_entries")
}

model SystemConfig {
  id        String   @id @default(cuid())
  adminId   String
  key       String
  value     Json
  updatedAt DateTime @default(now()) @updatedAt

  admin     UserMetadata @relation(fields: [adminId], references: [id])

  @@unique([key])
  @@map("system_config")
}

model GOPRequest {
  id               String    @id @default(cuid())
  status           String    @default("DRAFT")
  patientId        String
  insurerId        String
  assignedSurgeonId      String?
  assignedAnaesthetistId String?
  formData         Json?
  submittedAt      DateTime?
  expiresAt        DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  expiredAt        DateTime?
  stageEnteredAt   Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  insurer          InsurerConfig     @relation(fields: [insurerId], references: [id])
  notifications    Notification[]
  auditEntries     AuditEntry[]

  @@map("gop_requests")
}


generator client {
  provider = "prisma-client" 
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

model UserMetadata {
  id            String   @id @default(cuid())
  entraObjectId String   @unique
  displayName   String
  role          Role     @default(INSURANCE_STAFF)
  preferences   Json?    
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notifications Notification[]
  auditEntries  AuditEntry[]
  systemConfigs SystemConfig[]

  @@map("user_metadata")
}

model InsurerConfig {
  id                 String     @id @default(cuid())
  name               String  @unique
  contactEmail       String?
  emailTemplate      String?
  questionnaireFhirId String? // References FHIR Questionnaire ID
  coPayRuleSummary   String? // Human-readable from ANZER
  createdAt          DateTime @default(now())

  gopRequests GOPRequest[]

  @@map("insurer_config")
}

model NotificationRule {
  id        String @id @default(cuid())
  userId    String // Entra object ID
  eventType String // e.g. GOP_APPROVED, OVERDUE
  channel   String // email, in-app
  enabled   Boolean @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, eventType, channel])
  @@map("notification_rule")
}

model FeatureFlag {
  id      String @id @default(cuid())
  key     String @unique
  enabled Boolean @default(false)
  config  Json?

  @@map("feature_flag")
}

// Billing module — stores quotation data in the GOP database.
// HIS identifiers (departmentId, doctorId, insurerId, etc.) are stored as strings
// and denormalised names are also stored so the quote remains accurate if HIS data changes.
model BillingQuote {
  id                  String        @id @default(cuid())
  quoteNumber         String        @unique
  cpiId               String        @default("") // HIS CPIPersonal identifier
  patientName         String        @default("")
  dob                 DateTime?
  gender              String?
  phoneNumber         String?
  departmentId        String?       // HIS DeptID (reference only)
  departmentName      String?       // denormalised
  attendingDoctorId   String?       // HIS DoctorID
  attendingDoctorName String?       // denormalised
  lengthOfStay        Int?
  procedureCode       String?       // HIS ProcCode
  procedureName       String?       // denormalised
  diagnosisCode       String?
  diagnosisDescription String?      // denormalised
  provisionalDiagnosis String?
  doctorOrderSetId    String?
  doctorOrderSetName  String?       // denormalised
  pricingType         String        @default("NORMAL") // NORMAL | DIFFERENT
  differentPricingId  String?
  employerId          String?
  employerName        String?       // denormalised
  insurerId           String        @default("")  // HIS InsID
  insurerName         String        @default("")  // denormalised
  discountPackageId   String?
  discountPackageName String?       // denormalised
  marketingPackageId  String?
  marketingPackageName String?      // denormalised
  quoteDate           DateTime      @default(now())
  status              BillingStatus @default(DRAFT)
  totalNetAmount      Decimal       @default(0) @db.Decimal(12, 2)
  gopRequestId        String?       // FK to gop_requests if GOP created
  createdBy           String        // GOP user ID (UserMetadata.id or entraObjectId)
  createdByName       String        @default("")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  items               BillingQuoteItem[]

  @@index([cpiId])
  @@index([status])
  @@index([quoteDate])
  @@index([createdAt(sort: Desc)])
  @@map("billing_quotes")
}

model BillingQuoteItem {
  id          String       @id @default(cuid())
  quoteId     String
  department  String       @default("")
  type        String       @default("")
  code        String       @default("")
  description String       @default("")
  unit        Int          @default(1)
  price       Decimal      @default(0) @db.Decimal(12, 2)
  amount      Decimal      @default(0) @db.Decimal(12, 2) // unit * price
  discount    Decimal      @default(0) @db.Decimal(12, 2)
  netAmount   Decimal      @default(0) @db.Decimal(12, 2) // amount - discount
  sortOrder   Int          @default(0)

  quote       BillingQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("billing_quote_items")
}

enum Role {
  INSURANCE_STAFF
  FINANCE
  DOCTOR
  BILLING_STAFF
  IT_ADMIN
  ADMIN
}

